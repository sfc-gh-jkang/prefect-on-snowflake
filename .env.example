# Snowflake connection (for snow CLI and deploy scripts)
SNOWFLAKE_CONNECTION=my_connection

# Multi-environment: "dev", "staging", "prod" (default: "dev")
# Controls deployment name prefixing and env tags in Prefect.
PREFECT_ENV=dev

# Snowflake target database and schema (used by shared_utils and flows)
SNOWFLAKE_DATABASE=PREFECT_DB
SNOWFLAKE_SCHEMA=PREFECT_SCHEMA
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_ACCOUNT=your_account_locator

# Snowflake auth (Tier 3 fallback — used when no OAuth token or PAT is available)
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_HOST=your-org-account.snowflakecomputing.com

# SPCS image registry (from SHOW IMAGE REPOSITORIES)
SPCS_REGISTRY=your-org-account.registry.snowflakecomputing.com/prefect_db/prefect_schema/prefect_repository

# Prefect database password (used in compose and SPCS secrets)
POSTGRES_PASSWORD=change_me_in_production

# Prefect API URL (set after first deploy — used for deployments, hooks, and pool detection)
PREFECT_API_URL=https://xxx.snowflakecomputing.app/api

# SPCS server public endpoint (set after first deploy, used for flow deployment + hybrid workers)
PREFECT_SPCS_API_URL=https://xxx.snowflakecomputing.app/api

# Git-based deployment (optional, enables git_clone pull steps for all pools)
GIT_REPO_URL=https://your-git-host.com/org/repo.git
GIT_BRANCH=main
GIT_ACCESS_TOKEN=your-git-access-token

# Auth proxy — Snowflake PAT + SPCS endpoint (required for GCP/AWS workers AND local deploy)
# The local auth-proxy (make auth-proxy) uses these to bypass the SPCS auth gate,
# enabling `prefect deploy --all` from your local machine.
SNOWFLAKE_PAT=your-programmatic-access-token
SPCS_ENDPOINT=xxx.snowflakecomputing.app

# GCP worker config (optional, for hybrid testing)
GCP_PROJECT=your-gcp-project
GCP_ZONE=us-central1-a
GCP_VM_NAME=prefect-worker-gcp

# AWS worker config (optional, for hybrid testing)
AWS_PROFILE=your_aws_profile
AWS_REGION=us-west-2
AWS_INSTANCE_TYPE=t3.small
AWS_KEY_NAME=your-key-name
AWS_INSTANCE_NAME=your-prefect-worker-aws
AWS_SUBNET_ID=subnet-xxxxxxxxxxxxxxxxx
AWS_SECURITY_GROUP_ID=sg-xxxxxxxxxxxxxxxxx

# Monitoring endpoints (for GCP/hybrid worker monitoring sidecars)
# Set after PF_MONITOR is deployed. Used by docker-compose.monitoring.yml on remote workers.
SPCS_MONITOR_ENDPOINT=https://xxx.snowflakecomputing.app
SPCS_MONITOR_LOKI_ENDPOINT=https://xxx.snowflakecomputing.app

# Webhook alerting (optional — hooks.py sends notifications when set)
ALERT_WEBHOOK_URL=https://your-webhook-endpoint.example.com/alerts

# Slack alerting (opt-in — disabled by default)
# Set SLACK_ENABLED=true and provide a valid incoming webhook URL to enable.
# Create a webhook at: https://api.slack.com/apps → your app → Incoming Webhooks
# When enabled, deploy_monitoring.sh adds hooks.slack.com + api.slack.com egress rules.
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=<your-slack-incoming-webhook-url>

# Gmail SMTP alerting (optional — Grafana email contact point)
# Uses Google App Password (not regular password). Store in macOS Keychain
# as service "gmail-smtp" or set here. The deploy script checks Keychain first.
# IMPORTANT: Changing your Google password REVOKES all app passwords!
#   Regenerate at: https://myaccount.google.com/apppasswords
#   Then run:      ./scripts/rotate_secrets.sh --all-clouds --smtp
GRAFANA_SMTP_USER=your-email@gmail.com
GRAFANA_SMTP_RECIPIENTS=your-email@gmail.com
GRAFANA_SMTP_PASSWORD=xxxx xxxx xxxx xxxx

# Observe for Snowflake (O4S) — observe-agent config + Prometheus remote_write
# The observe-agent runs as a sidecar in SPCS (PF_MONITOR) and on VM workers.
# Token format: "<customer_id> <api_token>" (space-separated)
# Collection URL: https://<customer_id>.collect.observeinc.com
OBSERVE_TOKEN=175859677949 your-observe-api-token
OBSERVE_COLLECTION_URL=https://175859677949.collect.observeinc.com

# Observe Datastream Token — for Prometheus remote_write to Observe.
# IMPORTANT: This is a DATASTREAM token (ds1xxxxx:yyyyyy), NOT the user API token above.
# Used by: deploy_monitoring.sh → prometheus.yml (metrics remote_write).
# OTLP traces are routed through the observe-agent sidecar (localhost:4318)
# which uses the API token above — no datastream token needed for traces.
# Create via Observe GraphQL: mutation { createDatastreamToken(...) }
OBSERVE_DATASTREAM_TOKEN=ds1xxxxx:yyyyyy

# Snowflake role (used by docker-compose workers, defaults to ACCOUNTADMIN)
SNOWFLAKE_ROLE=ACCOUNTADMIN

# Prefect server telemetry (default: false — silences "Failed to send telemetry" noise in SPCS)
# Set to "true" to re-enable Prefect analytics phone-home.
PREFECT_SERVER_ANALYTICS_ENABLED=false

# Stage cleanup flow — retention period in days (default: 30)
STAGE_RETENTION_DAYS=30

# GitLab CI integration (optional — used by PAT rotation flow to update CI variables)
GITLAB_HOST=snow.gitlab-dedicated.com
GITLAB_PROJECT_ID=your_gitlab_project_id

# PAT rotation (optional — new PAT value for the rotation flow)
NEW_SNOWFLAKE_PAT=
