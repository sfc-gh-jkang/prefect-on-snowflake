[
  {
    "id": "stage-prefect-flow-runs",
    "pipeline": "filter OBSERVATION_KIND = \"prometheus\"\nmake_col metric_name:string(EXTRA.\"__name__\"), metric_value:float64(FIELDS.value), job:string(EXTRA.job)\nfilter metric_name = \"process_cpu_seconds_total\"\nmake_col OBSERVATION_KIND:job\ntimechart options(empty_bins:true), A_flow_runs:rate(metric_value), group_by(OBSERVATION_KIND)",
    "input": [
      {
        "datasetId": "${otel_raw_dataset_id}",
        "inputName": "prefect-spcs-observe-agent",
        "inputRole": "Data"
      }
    ],
    "layout": {
      "type": "table",
      "label": "Prefect CPU Rate by Job",
      "steps": [
        {
          "id": "si-stage-prefect-flow-runs",
          "opal": [],
          "type": "InputStep",
          "index": 0,
          "isPinned": false,
          "customName": "Input",
          "customSummary": ""
        },
        {
          "id": "se-stage-prefect-flow-runs",
          "opal": [
            "filter OBSERVATION_KIND = \"prometheus\"\nmake_col metric_name:string(EXTRA.\"__name__\"), metric_value:float64(FIELDS.value), job:string(EXTRA.job)\nfilter metric_name = \"process_cpu_seconds_total\"\nmake_col OBSERVATION_KIND:job\ntimechart options(empty_bins:true), A_flow_runs:rate(metric_value), group_by(OBSERVATION_KIND)"
          ],
          "type": "unknown",
          "index": 1,
          "isPinned": false,
          "customSummary": "OPAL Transform"
        }
      ],
      "managers": [
        {
          "id": "v-stage-prefect-flow-runs",
          "type": "Vis",
          "vegaVis": {
            "x": "_c_valid_from",
            "y": [
              "A_flow_runs"
            ],
            "type": "LineChart",
            "legend": {
              "type": "list",
              "visible": true
            },
            "xConfig": {
              "valueFormat": {
                "notation": "compact"
              }
            },
            "yConfig": {
              "show": true,
              "valueFormat": {
                "options": {
                  "notation": "compact"
                }
              }
            },
            "lineConfig": {
              "areaFillType": "TranslucentFill"
            },
            "color": "OBSERVATION_KIND"
          },
          "isDisabled": false
        }
      ],
      "viewModel": {
        "stageTab": "vis",
        "showTimeRuler": true
      }
    }
  },
