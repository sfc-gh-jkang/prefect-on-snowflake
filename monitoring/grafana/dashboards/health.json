    {
      "title": "Row: Flow Health",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Flow Success Rate",
      "description": "Ratio of COMPLETED runs to total terminal runs (recording rule).",
      "type": "gauge",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "prefect:flow_success_rate:ratio OR clamp_min(prefect_flow_runs{state=\"COMPLETED\"} / clamp_min(prefect_flow_runs{state=\"COMPLETED\"} + prefect_flow_runs{state=\"FAILED\"} + prefect_flow_runs{state=\"CRASHED\"}, 1), 0)",
          "legendFormat": "success rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 0.8, "color": "yellow" },
              { "value": 0.95, "color": "green" }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "links": [
        { "title": "Prefect App", "url": "/grafana/d/prefect-app", "targetBlank": false }
      ]
    },
    {
      "title": "Active Flow Runs",
      "description": "RUNNING + PENDING flow runs.",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 6, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "prefect:flow_runs_active:total OR (prefect_flow_runs{state=\"RUNNING\"} + prefect_flow_runs{state=\"PENDING\"})",
          "legendFormat": "active",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "blue" }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background_gradient",
        "graphMode": "none"
      },
      "links": [
        { "title": "Prefect App", "url": "/grafana/d/prefect-app", "targetBlank": false }
      ]
    },
    {
      "title": "Failed Runs",
      "description": "FAILED + CRASHED flow runs.",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 10, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "prefect:flow_runs_failed:total OR (prefect_flow_runs{state=\"FAILED\"} + prefect_flow_runs{state=\"CRASHED\"})",
          "legendFormat": "failed",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "orange" },
              { "value": 5, "color": "red" }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background_gradient",
        "graphMode": "none"
      },
      "links": [
        { "title": "Prefect App", "url": "/grafana/d/prefect-app", "targetBlank": false }
      ]
    },
    {
      "title": "Duration P50 (1h)",
