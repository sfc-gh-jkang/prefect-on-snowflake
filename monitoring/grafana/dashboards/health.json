  "schemaVersion": 39,
  "tags": ["prefect", "spcs", "health"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Prefect Health",
  "uid": "health",
  "version": 1
}
