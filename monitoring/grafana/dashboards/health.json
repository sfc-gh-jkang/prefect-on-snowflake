    {
      "title": "Workers per Pool",
      "description": "Active worker count per work pool.",
      "type": "bargauge",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
