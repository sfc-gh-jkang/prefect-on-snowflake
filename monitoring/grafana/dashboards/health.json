          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background_gradient",
        "graphMode": "none"
      },
      "links": [
        { "title": "Alerts Dashboard", "url": "/grafana/d/prefect-alerts", "targetBlank": false }
      ]
    },
