    {
      "title": "Row: Logs & Alerts",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Recent SPCS Error Logs",
      "description": "Latest ERROR-severity entries from SPCS event logs via Loki.",
      "type": "logs",
      "gridPos": { "h": 7, "w": 16, "x": 0, "y": 26 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=\"spcs-logs\", severity=\"ERROR\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      },
      "links": [
        { "title": "SPCS Logs", "url": "/grafana/d/prefect-spcs-logs", "targetBlank": false }
      ]
    },
    {
      "title": "Alert Rules Summary",
      "description": "Prometheus alert rules with current state.",
      "type": "table",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "ALERTS",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {}
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true },
            "renameByName": { "alertname": "Alert", "alertstate": "State", "severity": "Severity" }
          }
        }
      ],
      "links": [
        { "title": "Alerts Dashboard", "url": "/grafana/d/prefect-alerts", "targetBlank": false }
      ]
    },

    {
      "title": "Row: Workers",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "GCP Worker Flow Runs (5m rate)",
      "description": "Rate of flow run completions on GCP hybrid workers.",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(prefect_flow_runs{state=~\"COMPLETED|FAILED|CRASHED\"}[5m])",
          "legendFormat": "{{ state }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "fillOpacity": 10, "lineWidth": 1.5 }
        }
      },
      "links": [
        { "title": "VM Workers", "url": "/grafana/d/prefect-vm-workers", "targetBlank": false }
      ]
    },
    {
      "title": "Worker Logs Stream",
      "description": "Recent log lines from Prefect workers.",
      "type": "logs",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 34 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=\"spcs-logs\", container=~\".*worker.*\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      },
      "links": [
        { "title": "Logs Dashboard", "url": "/grafana/d/prefect-logs", "targetBlank": false }
      ]
    }
