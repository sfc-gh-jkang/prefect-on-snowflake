  "panels": [
    {
      "title": "",
      "type": "text",
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "# Prefect SPCS Health\nSingle pane of glass — click any section header or panel title to drill down."
      }
    },

    {
      "title": "Row: Service Status",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 2 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Services UP",
      "description": "Number of services reporting UP via Prometheus scrape targets.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "count(up{job=~\"prefect-server|prometheus|grafana|loki|redis|postgres|prefect-app\"} == 1) OR vector(0)",
          "legendFormat": "UP",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 5, "color": "yellow" },
              { "value": 7, "color": "green" }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background_gradient",
        "graphMode": "none"
      },
      "links": [
        { "title": "SPCS Overview", "url": "/grafana/d/prefect-spcs-overview", "targetBlank": false }
      ]
    },
    {
      "title": "Server Uptime (1h)",
      "description": "Prefect server uptime ratio over the last hour (recording rule).",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "prefect:server_uptime:ratio_1h OR avg_over_time(up{job=\"prefect-server\"}[1h])",
          "legendFormat": "1h uptime",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 0.95, "color": "yellow" },
              { "value": 0.99, "color": "green" }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background_gradient",
        "graphMode": "none"
      }
    },
    {
      "title": "Server Uptime (24h)",
      "description": "Prefect server uptime ratio over the last 24 hours.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "prefect:server_uptime:ratio_24h OR avg_over_time(up{job=\"prefect-server\"}[24h])",
          "legendFormat": "24h uptime",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 0.95, "color": "yellow" },
              { "value": 0.99, "color": "green" }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background_gradient",
        "graphMode": "none"
      }
    },
    {
      "title": "Firing Alerts",
      "description": "Number of currently firing Prometheus alerts.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 3 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "count(ALERTS{alertstate=\"firing\"}) OR vector(0)",
