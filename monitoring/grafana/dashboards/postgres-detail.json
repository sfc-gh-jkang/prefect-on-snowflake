{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [
    { "title": "Health Home", "url": "/grafana/d/health", "type": "link", "icon": "dashboard", "targetBlank": false },
    { "title": "SPCS Overview", "url": "/grafana/d/prefect-spcs-overview", "type": "link", "icon": "external link", "targetBlank": false },
    { "title": "Prefect App", "url": "/grafana/d/prefect-app", "type": "link", "icon": "external link", "targetBlank": false },
    { "title": "VM Workers", "url": "/grafana/d/prefect-vm-workers", "type": "link", "icon": "external link", "targetBlank": false },
    { "title": "Alerts", "url": "/grafana/d/prefect-alerts", "type": "link", "icon": "external link", "targetBlank": false },
    { "title": "SPCS Logs", "url": "/grafana/d/prefect-spcs-logs", "type": "link", "icon": "external link", "targetBlank": false },
    { "title": "Logs", "url": "/grafana/d/prefect-logs", "type": "link", "icon": "external link", "targetBlank": false },
    { "title": "Redis Detail", "url": "/grafana/d/prefect-redis-detail", "type": "link", "icon": "external link", "targetBlank": false }
  ],
  "panels": [
    {
      "title": "Tuple Operations Rate",
      "description": "Rate of inserts, updates, deletes, and fetches across all databases.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(pg_stat_database_tup_inserted{job=\"postgres\"}[5m]))",
          "legendFormat": "inserts/sec",
          "refId": "A"
        },
        {
          "expr": "sum(rate(pg_stat_database_tup_updated{job=\"postgres\"}[5m]))",
          "legendFormat": "updates/sec",
          "refId": "B"
        },
        {
          "expr": "sum(rate(pg_stat_database_tup_deleted{job=\"postgres\"}[5m]))",
          "legendFormat": "deletes/sec",
          "refId": "C"
        },
        {
          "expr": "sum(rate(pg_stat_database_tup_fetched{job=\"postgres\"}[5m]))",
          "legendFormat": "fetches/sec",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "fillOpacity": 20 }
        }
      }
    },
    {
      "title": "Dead Tuples vs Live Tuples",
      "description": "Dead and live tuple counts across user tables. High dead tuple count means VACUUM is needed.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(pg_stat_user_tables_n_live_tup{job=\"postgres\"})",
          "legendFormat": "live tuples",
          "refId": "A"
        },
        {
          "expr": "sum(pg_stat_user_tables_n_dead_tup{job=\"postgres\"})",
          "legendFormat": "dead tuples",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 20 }
        }
      }
    },
    {
      "title": "Table Size (Top 10)",
      "description": "Total size of the largest tables including indexes and TOAST.",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "topk(10, pg_stat_user_tables_table_size_bytes{job=\"postgres\"})",
          "legendFormat": "{{ relname }}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "blue" }
            ]
          }
        }
      }
    },
    {
      "title": "Index Hit Ratio",
      "description": "Ratio of index scans to total scans (index + sequential). Higher is better.",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(pg_stat_user_tables_idx_scan{job=\"postgres\"}) / (sum(pg_stat_user_tables_idx_scan{job=\"postgres\"}) + sum(pg_stat_user_tables_seq_scan{job=\"postgres\"})) * 100",
          "legendFormat": "index hit ratio",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 80, "color": "yellow" },
              { "value": 95, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "title": "Locks by Mode",
      "description": "Current locks grouped by mode.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (mode) (pg_locks_count{job=\"postgres\"})",
          "legendFormat": "{{ mode }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 30, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "title": "Temp Bytes Written",
      "description": "Rate of temporary file bytes written, indicating sorts/joins spilling to disk.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(pg_stat_database_temp_bytes{job=\"postgres\"}[5m]))",
          "legendFormat": "temp bytes/sec",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "custom": { "fillOpacity": 30 }
        }
      }
    },
    {
      "title": "Database Size",
      "description": "Total size of each database.",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "pg_database_size_bytes{job=\"postgres\"}",
          "legendFormat": "{{ datname }}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value_and_name",
        "colorMode": "background_gradient"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "blue" }
            ]
          }
        }
      }
    },
    {
      "title": "Exporter Scrape Duration",
      "description": "How long each postgres-exporter scrape takes.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "pg_exporter_last_scrape_duration_seconds{job=\"postgres\"}",
          "legendFormat": "scrape duration",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "fillOpacity": 20 }
        }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["prefect", "postgres"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Prefect — Postgres Detail",
  "uid": "prefect-postgres-detail"
}
