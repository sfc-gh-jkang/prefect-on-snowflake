{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [
    { "title": "Health Home", "url": "/grafana/d/health", "type": "link", "icon": "dashboard", "targetBlank": false },
    { "title": "SPCS Overview", "url": "/grafana/d/prefect-spcs-overview", "type": "link", "icon": "external link", "targetBlank": false },
    { "title": "Prefect App", "url": "/grafana/d/prefect-app", "type": "link", "icon": "external link", "targetBlank": false },
    { "title": "VM Workers", "url": "/grafana/d/prefect-vm-workers", "type": "link", "icon": "external link", "targetBlank": false },
    { "title": "Alerts", "url": "/grafana/d/prefect-alerts", "type": "link", "icon": "external link", "targetBlank": false },
    { "title": "Logs", "url": "/grafana/d/prefect-logs", "type": "link", "icon": "external link", "targetBlank": false },
    { "title": "Redis Detail", "url": "/grafana/d/prefect-redis-detail", "type": "link", "icon": "external link", "targetBlank": false },
    { "title": "Postgres Detail", "url": "/grafana/d/prefect-postgres-detail", "type": "link", "icon": "external link", "targetBlank": false }
  ],
  "panels": [
    {
      "title": "SPCS Log Volume",
      "description": "Rate of log lines per second from SPCS services, grouped by service and container.",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by(service, container) (rate({job=\"spcs-logs\", service=~\"$service\"} [$__interval]))",
          "legendFormat": "{{ service }}/{{ container }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "fillOpacity": 30, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "title": "SPCS Error Rate",
      "description": "Rate of ERROR/FATAL/CRITICAL log lines from SPCS services.",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by(service) (rate({job=\"spcs-logs\", service=~\"$service\"} |~ \"(?i)(ERROR|FATAL|CRITICAL)\" [$__interval]))",
          "legendFormat": "{{ service }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": { "fillOpacity": 30 }
        }
      }
    },
    {
      "title": "SPCS Log Severity Distribution",
      "description": "Log lines grouped by severity level.",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by(severity) (rate({job=\"spcs-logs\", service=~\"$service\"} [$__interval]))",
          "legendFormat": "{{ severity }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "fillOpacity": 30, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "title": "SPCS Log Stream",
      "description": "Live log stream from SPCS services. Filter by service, container, and free-text search.",
      "type": "logs",
      "gridPos": { "h": 24, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=\"spcs-logs\", service=~\"$service\", container=~\"$container\"} |~ \"$search\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "title": "SPCS Error Logs",
      "description": "Log lines containing error-level keywords from SPCS services.",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 36 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=\"spcs-logs\", service=~\"$service\"} |~ \"(?i)(error|exception|fatal|panic|traceback)\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["prefect", "spcs", "logs"],
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "definition": "label_values({job=\"spcs-logs\"}, service)",
        "query": "label_values({job=\"spcs-logs\"}, service)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "multi": true,
        "sort": 1
      },
      {
        "name": "container",
        "label": "Container",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "definition": "label_values({job=\"spcs-logs\"}, container)",
        "query": "label_values({job=\"spcs-logs\"}, container)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "multi": true,
        "sort": 1
      },
      {
        "name": "search",
        "label": "Search",
        "type": "textbox",
        "current": { "text": "", "value": "" },
        "options": []
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Prefect — SPCS Logs",
  "uid": "prefect-spcs-logs"
}
