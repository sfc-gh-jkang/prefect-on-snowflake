    { "title": "Redis Detail", "url": "/grafana/d/prefect-redis-detail", "type": "link", "icon": "external link", "targetBlank": false },
    { "title": "Postgres Detail", "url": "/grafana/d/prefect-postgres-detail", "type": "link", "icon": "external link", "targetBlank": false }
  ],
  "panels": [
    {
      "title": "Log Volume",
      "description": "Rate of log lines per second, grouped by worker location and stream (stdout/stderr).",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by(worker_location, stream) (rate({job=~\".+\", worker_location=~\"$worker_location\"} [$__interval]))",
          "legendFormat": "{{ worker_location }} ({{ stream }})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "fillOpacity": 30, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "title": "Log Stream",
      "description": "Live log stream from all VM workers. Filter by worker location, stream type, and free-text search.",
      "type": "logs",
      "gridPos": { "h": 24, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=~\".+\", worker_location=~\"$worker_location\", stream=~\"$stream\"} |~ \"$search\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "title": "Error Logs",
      "description": "Log lines containing error-level keywords, filtered by worker location.",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 30 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=~\".+\", worker_location=~\"$worker_location\", stream=\"stderr\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["prefect", "logs"],
  "templating": {
    "list": [
      {
        "name": "worker_location",
        "label": "Worker Location",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "definition": "label_values(worker_location)",
        "query": "label_values(worker_location)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "multi": true,
        "sort": 1
      },
      {
        "name": "stream",
        "label": "Stream",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "definition": "label_values(stream)",
        "query": "label_values(stream)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "multi": true,
        "sort": 1
      },
      {
        "name": "search",
        "label": "Search",
        "type": "textbox",
        "current": { "text": "", "value": "" },
        "options": []
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Prefect — Logs",
  "uid": "prefect-logs"
}
